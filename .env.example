NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:3000

# Gmail account used by Nodemailer to send contact form emails.
EMAIL_USER=your-team-email@gmail.com

# Gmail App Password for EMAIL_USER. Do not use a normal Gmail password.
EMAIL_PASS=your_16_character_app_password

# School-controlled inbox or distribution list that receives team notification emails.
EMAIL_TO=your_school_controlled_inbox@example.org

# hCaptcha site key shown in the browser.
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# hCaptcha secret used only by the server.
HCAPTCHA_SECRET=your_hcaptcha_secret

# Leave as-is unless hCaptcha changes the official verification endpoint.
HCAPTCHA_VERIFY_URL=https://api.hcaptcha.com/siteverify

# 64-character hexadecimal key used to encrypt failed-delivery recovery records at rest.
BACKUP_ENCRYPTION_KEY=change_me_with_64_hex_chars
